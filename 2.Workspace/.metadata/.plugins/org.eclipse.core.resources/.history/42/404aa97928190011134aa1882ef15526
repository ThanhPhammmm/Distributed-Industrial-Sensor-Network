		while(xQueueReceive(xQueue_RS485_RxFrame, &frame, 0) == pdTRUE){
            SlaveProtoState_t *s = _findSlaveByName(frame.addr);
            if (s == NULL){
                continue;
            }

            if(frame.seq != s->txSeq){
                continue;
            }
		}

