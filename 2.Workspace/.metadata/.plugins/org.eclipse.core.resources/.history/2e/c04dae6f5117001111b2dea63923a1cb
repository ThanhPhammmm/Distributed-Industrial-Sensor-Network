#include "DeviceManager.h"

void DeviceManager_Init(void){

}

void DeviceManager_Task(void *pvParams){
    (void)pvParams;
    Frame_t frame;

    while(1){
        /* Try to receive one frame; very short timeout so state machine
         * continues even with no incoming frames (scan advance, etc.)  */
        const bool gotFrame = (xQueueReceive(xQueue_ValidFrame, &frame, pdMS_TO_TICKS(DEVMGR_TASK_LOOP_MS)) == pdTRUE);

        xSemaphoreTake(g_mutex, portMAX_DELAY);

        if (gotFrame) {
            if (frame.cmd == 0xFFU) {
                /* Offline sentinel from Protocol_Task */
                _OnOffline(frame.addr);
            } else {
                if (!_HandleResponse(&frame)) {
                    LOG_W(TAG, "Unsolicited frame 0x%02X cmd=0x%02X",
                          frame.addr, frame.cmd);
                }
            }
        }

        if (_PendingTimedOut())
            _HandleTimeout();

        if (g_pending.op == OP_NONE)
            _Advance();

        xSemaphoreGive(g_mutex);

        Watchdog_Checkin(WDT_TASK_DEVMGR);
    }
}
